# EditorConfig for consistent formatting

root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
indent_size = 2
trim_trailing_whitespace = false

[*.json]
indent_size = 2

[*.{cs,csproj}]
indent_size = 4
indent_style = space

[*.sh]
indent_size = 2
end_of_line = lf

[*.yml,*.yaml]
indent_size = 2

[Makefile]
indent_style = tab
